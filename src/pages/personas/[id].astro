---
// src/pages/personas/[id].astro
import MainLayout from '@/layouts/MainLayout.astro'
import PersonaDetalle from '@/components/personas/PersonaDetalle'

const { id } = Astro.params
---

<MainLayout title="Perfil Académico | UCB">
  <section class="py-12 bg-slate-50 min-h-screen pt-32">
    <div class="container-custom max-w-5xl">
      <a href="/personas" class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:text-indigo-800 mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        Volver al Directorio
      </a>

      {/* Cargamos el detalle directamente, ya que el componente se auto-abastece con withQueryClient */}
      <PersonaDetalle personaId={parseInt(id!)} client:only="react" />
    </div>
  </section>
</MainLayout>