---
// frontend/src/pages/login.astro
import MainLayout from '@/layouts/MainLayout.astro'
import LoginForm from '@/components/auth/LoginForm'

const { searchParams } = Astro.url
const error = searchParams.get('error')
---

<MainLayout title="Iniciar Sesión | UCB">
  <div class="min-h-screen bg-slate-50 flex flex-col justify-center py-20">
    <div class="container-custom max-w-md relative z-10">
      
      <div class="text-center mb-10">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm mb-6">
          <span class="bg-gradient-to-br from-indigo-600 to-cyan-500 bg-clip-text text-3xl font-black text-transparent">D</span>
        </div>
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Portal Administrativo</h1>
        <p class="mt-3 text-slate-500">Ingresa con tus credenciales de docente o administrador.</p>
      </div>

      <div class="bg-white py-10 px-8 rounded-3xl shadow-xl border border-slate-100">
        {error === 'unauthorized' && (
          <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-xl text-amber-800 text-sm font-semibold flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            Tu sesión ha expirado o no tienes permisos para acceder. Por favor, inicia sesión nuevamente.
          </div>
        )}

        {/* Carga limpia, sin envolturas defectuosas de Astro */}
        <LoginForm client:only="react" />
      </div>

      <div class="mt-8 text-center">
        <a href="/" class="text-sm font-semibold text-slate-500 hover:text-indigo-600 transition-colors">
          ← Volver al sitio público
        </a>
      </div>
    </div>
  </div>
</MainLayout>