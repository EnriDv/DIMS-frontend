---
// frontend/src/pages/noticias/[id].astro
import MainLayout from '@/layouts/MainLayout.astro'
import { noticiasService } from '@/lib/api/noticias.service'

const { id } = Astro.params
const noticiaId = Number(id)

let noticia = null

if (!Number.isNaN(noticiaId)) {
  try {
    noticia = await noticiasService.getById(noticiaId)
  } catch {
    Astro.response.status = 404
  }
} else {
  Astro.response.status = 404
}

const pageTitle = noticia ? `${noticia.titulo} | Noticias UCB` : 'Noticia no encontrada | UCB'
---

<MainLayout title={pageTitle}>
  {!noticia ? (
    <section class="relative min-h-screen bg-white pt-32 pb-20">
      <div class="container-custom max-w-3xl text-center">
        <h1 class="text-3xl font-black text-slate-900">Noticia no encontrada</h1>
        <p class="mt-4 text-slate-600">Esta noticia no existe o fue eliminada.</p>
        <a href="/noticias" class="mt-8 inline-flex rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white hover:bg-indigo-700">
          Volver a noticias
        </a>
      </div>
    </section>
  ) : (
    <div class="relative min-h-screen bg-white pt-32 pb-20">
      <article class="container-custom max-w-4xl">
        <a href="/noticias" class="inline-flex items-center gap-2 text-indigo-600 font-semibold hover:text-indigo-800 mb-8 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Volver al feed
        </a>

        <header class="mb-10">
          <div class="mb-6 flex flex-wrap items-center gap-4 font-mono text-xs font-bold text-slate-500 uppercase">
            <span class="rounded-md bg-indigo-50 px-3 py-1 text-indigo-700 tracking-widest border border-indigo-100">Comunicado</span>
            <span>{new Date(noticia.fecha).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            {noticia.carreraNombre && (
              <>
                <span>•</span>
                <span class="text-cyan-600">{noticia.carreraNombre}</span>
              </>
            )}
          </div>

          <h1 class="mb-8 text-4xl md:text-5xl leading-tight font-black text-slate-900 tracking-tight">
            {noticia.titulo}
          </h1>
        </header>

        {noticia.imagenUrl && (
          <div class="mb-12 aspect-video w-full overflow-hidden rounded-2xl shadow-lg border border-slate-200">
            <img
              src={noticia.imagenUrl}
              alt={noticia.titulo}
              class="h-full w-full object-cover"
            />
          </div>
        )}

        <div class="prose prose-lg prose-slate prose-a:text-indigo-600 hover:prose-a:text-indigo-800 max-w-none">
          <Fragment set:html={noticia.contenido} />
        </div>
      </article>
    </div>
  )}
</MainLayout>