---
// src/pages/materias/[id].astro
import MainLayout from '@/layouts/MainLayout.astro'
import MateriaDetalle from '@/components/materias/MateriaDetalle' 

const { id } = Astro.params
---

<MainLayout title="Detalle de Materia | UCB">
  <section class="py-12 bg-slate-50 min-h-screen pt-32">
    <div class="container-custom max-w-5xl">
      <a
        href="/materias"
        class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:text-indigo-800 mb-8 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver a la Malla
      </a>

      {/* Componente limpio sin QueryProvider externo */}
      <MateriaDetalle materiaId={parseInt(id!)} client:only="react" />
    </div>
  </section>
</MainLayout>