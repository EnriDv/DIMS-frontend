---
// src/pages/carreras/[slug]/index.astro
import MainLayout from '@/layouts/MainLayout.astro'
import MateriasPreview from '@/components/materias/MateriasPreview'
import DocentesPreview from '@/components/personas/DocentesPreview'
import { api } from '@/lib/api/client'

const { slug } = Astro.params

let carrera = null
if (slug) {
  try {
    const carreras = await api.get<any[]>('/Carreras')
    carrera = carreras.find((c: any) => c.slug === slug)
  } catch (e) {
    console.error('Error fetching carrera:', e)
  }
}
---

<MainLayout title={carrera ? `${carrera.nombre} | UCB` : 'Carrera no encontrada | UCB'}>
  {!carrera ? (
    <section class="relative min-h-screen bg-white pt-32 pb-20">
      <div class="container-custom max-w-3xl text-center">
        <h1 class="text-3xl font-black text-slate-900">Carrera no encontrada</h1>
        <a href="/carreras" class="mt-8 inline-block text-indigo-600 font-bold hover:text-indigo-800">
          ← Volver a Carreras
        </a>
      </div>
    </section>
  ) : (
    <>
      <section class="py-20 bg-white border-b border-slate-100 pt-32">
        <div class="container-custom">
          <div class="max-w-4xl">
            <span class="text-7xl mb-6 block">{carrera.icono || '🎓'}</span>
            <h1 class="text-5xl font-black text-slate-900 mb-6 tracking-tight">{carrera.nombre}</h1>
            <p class="text-xl text-slate-600 leading-relaxed mb-10">{carrera.descripcion}</p>
          </div>
        </div>
      </section>

      <section class="py-16 bg-slate-50">
        <div class="container-custom">
          <div class="mb-20">
            <h2 class="text-sm font-black text-indigo-600 uppercase tracking-widest mb-6">Vista_Malla_Curricular</h2>
            <MateriasPreview carreraSlug={carrera.slug} client:only="react" />
          </div>

          <div>
            <h2 class="text-sm font-black text-indigo-600 uppercase tracking-widest mb-6">Staff_Docente_Unidad</h2>
            <DocentesPreview carreraSlug={carrera.slug} client:only="react" />
          </div>
        </div>
      </section>
    </>
  )}
</MainLayout>