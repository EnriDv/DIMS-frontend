---
// src/pages/carreras/[slug]/malla.astro
import MainLayout from '@/layouts/MainLayout.astro'
import MateriasLista from '@/components/materias/MateriasLista'

const { slug } = Astro.params
const { carrera } = Astro.props
---

<MainLayout title={`Malla Curricular | ${carrera.nombre}`}>
  <section class="py-12 bg-slate-50 min-h-screen pt-32">
    <div class="container-custom">
      <a href={`/carreras/${carrera.slug}`} class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:text-indigo-800 mb-8 transition-colors text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        VOLVER_A_SINOPSIS
      </a>

      <div class="mb-12 flex items-end justify-between border-b border-slate-200 pb-8">
        <div>
          <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight uppercase">MALLA_CURRICULAR</h1>
          <p class="text-xl font-medium text-indigo-600 font-mono tracking-widest">{carrera.nombre.toUpperCase()}</p>
        </div>
        <div class="hidden md:block">
           <span class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-400 font-mono uppercase">Version_Control: v2.0</span>
        </div>
      </div>

      <MateriasLista client:only="react" />
    </div>
  </section>

  <script>
    import { setCarreraActiva } from '@/stores/filters'
    const pathname = window.location.pathname;
    const parts = pathname.split('/');
    const slugIndex = parts.indexOf('carreras') + 1;
    if (slugIndex > 0 && parts[slugIndex]) {
      setCarreraActiva(parts[slugIndex]);
    }
  </script>
</MainLayout>