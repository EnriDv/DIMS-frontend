---
// src/pages/index.astro
import MainLayout from '@/layouts/MainLayout.astro'
import { carreras, noticias } from '@/lib/mockData'

const ultimasNoticias = noticias.slice(0, 3)
---

<MainLayout 
  title="DIMS UCB - Engineering Hub" 
  description="Liderando la vanguardia tecnológica en IA, Software y Mecatrónica."
>
  
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-slate-950">
    <div class="absolute inset-0 z-0 opacity-20" 
         style="background-image: radial-gradient(#334155 1px, transparent 1px); background-size: 40px 40px;">
    </div>
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-indigo-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-cyan-600/20 rounded-full blur-[120px]"></div>

    <div class="container-custom relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-400 text-xs font-mono mb-6 animate-pulse">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
            </span>
            SISTEMA_OPERATIVO_V4.0
          </div>
          <h1 class="text-6xl lg:text-8xl font-black mb-6 leading-[0.9] tracking-tighter">
            BUILD.<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-cyan-400 to-purple-500">INNOVATE.</span><br/>
            DEPLOY.
          </h1>
          <p class="text-slate-400 text-lg lg:text-xl mb-8 max-w-lg leading-relaxed font-light">
            No solo estudiamos tecnología; la <span class="text-white font-medium">ejecutamos</span>. 
            Únete al hub de ingeniería más avanzado de la UCB.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#carreras" class="btn-primary">
              EXPLORAR_STACK
            </a>
            <a href="/noticias" class="px-6 py-3 rounded-lg font-semibold border border-white/10 hover:bg-white/5 transition-all flex items-center gap-2">
              <span class="w-2 h-2 bg-slate-500 rounded-full"></span>
              VER_LOGS
            </a>
          </div>
        </div>

        <div class="hidden lg:block relative">
          <div class="glass-card p-2 border-cyan-500/20 shadow-2xl shadow-cyan-500/10">
            <div class="bg-slate-950 rounded-xl p-6 font-mono text-sm overflow-hidden">
               <p class="text-green-400">$ init project --dims</p>
               <p class="text-slate-500">Loading neural_network_modules...</p>
               <p class="text-cyan-400">Status: High Performance Detected</p>
               <div class="mt-4 grid grid-cols-2 gap-2">
                 <div class="h-20 bg-slate-900 rounded border border-white/5 animate-pulse"></div>
                 <div class="h-20 bg-slate-900 rounded border border-white/5"></div>
               </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-white/5 bg-slate-950/50">
    <div class="container-custom py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { label: 'Empleabilidad', val: '95%', color: 'text-cyan-400' },
          { label: 'Graduados', val: '+500', color: 'text-indigo-400' },
          { label: 'Proyectos_Active', val: '150+', color: 'text-purple-400' },
          { label: 'Convenios_Global', val: '50+', color: 'text-pink-400' },
        ].map(stat => (
          <div class="text-center border-r border-white/5 last:border-0">
            <div class={`text-3xl font-black ${stat.color}`}>{stat.val}</div>
            <div class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="carreras" class="py-24 relative">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-xs font-mono text-cyan-500 mb-2 uppercase tracking-[0.3em]">Directorio_de_Carreras</h2>
        <h3 class="text-4xl lg:text-5xl font-bold">Elige tu <span class="italic text-slate-500">stack</span></h3>
      </div>

      <div class="space-y-4">
        {carreras.map((carrera) => (
          <a 
            href={`/carreras/${carrera.slug}`}
            class="group block glass-card p-6 lg:p-10 hover:bg-white/5 transition-all duration-500 border-white/5 hover:border-cyan-500/30 overflow-hidden relative"
          >
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-cyan-500/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"></div>
            
            <div class="flex flex-col md:flex-row md:items-center gap-8 relative z-10">
              <div class="text-6xl grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-110">
                {carrera.icono}
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h4 class="text-2xl font-bold text-white group-hover:text-cyan-400 transition-colors">
                    {carrera.nombre}
                  </h4>
                  <span class="text-[10px] font-mono px-2 py-0.5 border border-white/10 rounded uppercase text-slate-500">
                    {carrera.duracion}
                  </span>
                </div>
                <p class="text-slate-400 max-w-2xl line-clamp-2 font-light">
                  {carrera.descripcion}
                </p>
              </div>
              <div class="text-slate-700 group-hover:text-cyan-500 transition-colors">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-900/30">
    <div class="container-custom">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-xs font-mono text-indigo-500 mb-2 uppercase tracking-[0.3em]">System_Logs</h2>
          <h3 class="text-4xl font-bold">Código en producción</h3>
        </div>
        <a href="/noticias" class="text-sm font-mono text-slate-500 hover:text-white transition-colors">VIEW_ALL_LOGS</a>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {ultimasNoticias.map((noticia) => (
          <article class="glass-card overflow-hidden group border-white/5">
            <div class="h-48 relative overflow-hidden">
              <img src={noticia.imagen} alt={noticia.titulo} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-60 group-hover:opacity-100" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent"></div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-2 h-2 bg-cyan-500 rounded-full"></span>
                <time class="font-mono text-[10px] text-slate-500 uppercase">{noticia.fecha}</time>
              </div>
              <h4 class="text-lg font-bold mb-4 line-clamp-2 group-hover:text-indigo-400 transition-colors">
                {noticia.titulo}
              </h4>
              <a href={`/noticias/${noticia.id}`} class="inline-flex items-center gap-2 text-xs font-mono text-cyan-500 hover:text-cyan-300">
                READ_ENTRY <span class="group-hover:translate-x-1 transition-transform">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container-custom">
      <div class="relative rounded-3xl p-12 overflow-hidden border border-cyan-500/20 bg-slate-900 shadow-[0_0_50px_rgba(34,211,238,0.05)]">
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-cyan-500/10 rounded-full blur-[80px]"></div>
        
        <div class="relative z-10 max-w-2xl">
          <h2 class="text-5xl font-black mb-6 leading-tight">Postulaciones <span class="text-cyan-400 underline decoration-cyan-500/30">Abiertas</span></h2>
          <p class="text-slate-400 text-xl mb-8">
            El sistema está listo para procesar nuevas solicitudes. Inicia tu proceso de admisión para el semestre 1-2026.
          </p>
          <div class="flex flex-wrap gap-4">
            <button class="bg-cyan-500 hover:bg-cyan-400 text-slate-950 px-8 py-4 rounded-lg font-bold transition-all shadow-lg shadow-cyan-500/20">
              APLICAR_AHORA
            </button>
            <button class="px-8 py-4 rounded-lg font-bold border border-white/10 hover:bg-white/5 transition-all">
              DESCARGAR_BROCHURE.pdf
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* Optimizaciones de texto para look tech */
  h1, h2, h3, h4 {
    text-wrap: balance;
  }
</style>