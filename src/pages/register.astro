---
// frontend/src/pages/register.astro
import MainLayout from '@/layouts/MainLayout.astro'
import RegisterForm from '@/components/auth/RegisterForm'
---

<MainLayout title="Crear Cuenta | UCB">
  <div class="min-h-screen bg-slate-50 flex flex-col justify-center py-20">
    <div class="container-custom max-w-md relative z-10">
      
      <div class="text-center mb-10">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm mb-6">
          <span class="bg-gradient-to-br from-indigo-600 to-cyan-500 bg-clip-text text-3xl font-black text-transparent">D</span>
        </div>
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Registro</h1>
        <p class="mt-3 text-slate-500">Crea una cuenta para acceder al sistema.</p>
      </div>

      <div class="bg-white py-10 px-8 rounded-3xl shadow-xl border border-slate-100">
        <RegisterForm client:only="react" />
      </div>

      <div class="mt-8 text-center space-y-4">
        <p class="text-sm font-semibold text-slate-500">
          ¿Ya tienes cuenta? <a href="/login" class="text-indigo-600 hover:text-indigo-800 transition-colors">Inicia sesión</a>
        </p>
        <a href="/" class="block text-sm font-semibold text-slate-500 hover:text-indigo-600 transition-colors">
          ← Volver al sitio público
        </a>
      </div>
    </div>
  </div>
</MainLayout>
