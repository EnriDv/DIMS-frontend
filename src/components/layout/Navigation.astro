---
interface Props {
  currentPath: string
  mobile?: boolean
}

const { currentPath, mobile = false } = Astro.props

// Configuración centralizada de rutas
const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Carreras', href: '/#carreras' }, // Ancla a la sección de la Home
  { name: 'Noticias', href: '/noticias' },
  { name: 'Eventos', href: '/eventos' },
  { name: 'Investigaciones', href: '/investigaciones' },
]

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/'
  if (href.startsWith('/#')) return false // Las anclas no se marcan como "activas" por URL
  return currentPath.startsWith(href)
}
---

<nav class={mobile ? 'py-6' : 'hidden md:block'}>
  <ul class={mobile ? 'space-y-4' : 'flex items-center gap-2'}>
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`group relative rounded-lg px-4 py-2 text-sm font-medium transition-all duration-300 ${mobile ? 'block text-lg' : 'inline-block'} ${
              isActive(item.href)
                ? 'text-cyan-400'
                : 'text-slate-400 hover:bg-white/5 hover:text-white'
            } `}
          >
            {item.name}

            {isActive(item.href) && (
              <span class="absolute right-4 bottom-0 left-4 h-0.5 bg-cyan-400 shadow-[0_0_12px_rgba(34,211,238,0.8)]" />
            )}

            {!isActive(item.href) && (
              <span class="absolute bottom-0 left-1/2 h-0.5 w-0 bg-indigo-500 transition-all duration-300 group-hover:left-1/4 group-hover:w-1/2" />
            )}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
