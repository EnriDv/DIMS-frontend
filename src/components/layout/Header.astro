---
import LoginButton from '../auth/LoginButton'
// frontend/src/components/layout/Header.astro
import Navigation from './Navigation.astro'

const currentPath = Astro.url.pathname
---

<header class="fixed top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md shadow-sm">
  <div class="container-custom">
    <div class="flex h-20 items-center justify-between">
      <a href="/" class="group flex items-center gap-3">
        <div class="relative flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 shadow-inner">
          <span class="bg-gradient-to-br from-indigo-600 to-cyan-500 bg-clip-text text-xl font-black text-transparent">D</span>
        </div>
        <div class="flex flex-col">
          <span class="text-xl font-bold tracking-tighter text-slate-900">DIMS</span>
          <span class="font-mono text-[10px] leading-none tracking-[0.2em] text-indigo-500 uppercase">Engineering Hub</span>
        </div>
      </a>

      <div class="hidden md:block">
        <Navigation currentPath={currentPath} />
      </div>

      <div class="flex items-center gap-4">
        
        {/* Aquí inyectamos el botón de Login dinámico */}
        <div class="hidden lg:block">
          <LoginButton client:only="react" />
        </div>

        <button
          id="mobile-menu-button"
          class="p-2 text-slate-500 hover:text-slate-900 md:hidden"
          aria-label="Menu"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden h-screen border-t border-slate-200 bg-white md:hidden">
    <div class="p-6">
      <Navigation currentPath={currentPath} mobile={true} />
      
      {/* Botón de Login en el menú móvil */}
      <div class="mt-8 flex justify-center border-t border-slate-100 pt-6">
        <LoginButton client:only="react" />
      </div>
    </div>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button')
  const menu = document.getElementById('mobile-menu')
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
    document.body.classList.toggle('overflow-hidden')
  })
</script>