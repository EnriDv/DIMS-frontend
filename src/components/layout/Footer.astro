---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-slate-950 border-t border-white/5 pt-20 pb-10 overflow-hidden">
  {/* Decoración: Gradiente de fondo sutil */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-indigo-600/10 rounded-full blur-[120px]"></div>

  <div class="container-custom relative z-10">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      
      <div class="md:col-span-2 space-y-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 bg-slate-900 border border-white/10 rounded-xl flex items-center justify-center shadow-[0_0_15px_rgba(99,102,241,0.2)]">
            <span class="text-white font-black text-2xl">D</span>
          </div>
          <div>
            <span class="text-2xl font-bold tracking-tighter text-white">DIMS <span class="text-cyan-400">UCB</span></span>
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Advanced Research Lab</p>
          </div>
        </div>
        <p class="text-slate-400 max-w-md leading-relaxed text-sm">
          Ecosistema de innovación donde la ingeniería y la ciencia convergen para desarrollar las tecnologías que definirán la próxima década.
        </p>
        
        <div class="flex gap-4">
          {['Facebook', 'Twitter', 'LinkedIn'].map((social) => (
            <a href="#" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-cyan-400 hover:border-cyan-400/50 hover:shadow-[0_0_15px_rgba(34,211,238,0.2)] transition-all">
              <span class="sr-only">{social}</span>
              {/* Aquí irían tus SVGs actuales */}
              <div class="w-5 h-5 bg-current" style="mask: url(/icons/social.svg); -webkit-mask: url(/icons/social.svg);"></div>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-white font-bold mb-6 flex items-center gap-2">
          <span class="w-1 h-4 bg-cyan-500 rounded-full"></span>
          Directorio
        </h3>
        <ul class="space-y-3 font-mono text-xs">
          {[
            { n: 'Investigaciones', h: '/investigaciones' },
            { n: 'Eventos_Anuales', h: '/eventos' },
            { n: 'Core_Members', h: '/miembros' },
            { n: 'Repositorio_Proyectos', h: '/proyectos' }
          ].map(link => (
            <li>
              <a href={link.h} class="text-slate-500 hover:text-cyan-400 transition-colors flex items-center gap-2 group">
                <span class="text-cyan-500/0 group-hover:text-cyan-500 transition-all">{'>'}</span>
                {link.n}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold mb-6 flex items-center gap-2">
          <span class="w-1 h-4 bg-indigo-500 rounded-full"></span>
          Terminal_Info
        </h3>
        <div class="space-y-4 font-mono text-[11px]">
          <div class="p-3 rounded-lg bg-white/5 border border-white/5">
            <p class="text-slate-500 mb-1">EMAIL_ADDRESS</p>
            <p class="text-indigo-300">ejemplo@ucb.edu.bo</p>
          </div>
          <div class="p-3 rounded-lg bg-white/5 border border-white/5">
            <p class="text-slate-500 mb-1">LOCATION_REF</p>
            <p class="text-indigo-300">Campus UCB, Santa Cruz - BO</p>
          </div>
        </div>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[10px] font-mono text-slate-600 uppercase tracking-widest">
        &copy; {currentYear} DIMS v1.0.0 - Todos los privilegios reservados.
      </p>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span class="text-[10px] font-mono text-slate-500 uppercase">System_Status: Online</span>
      </div>
    </div>
  </div>
</footer>