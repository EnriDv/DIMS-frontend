---
// src/components/layout/Footer.astro
const currentYear = new Date().getFullYear()
---

<footer class="relative overflow-hidden border-t border-slate-200 bg-white pt-20 pb-10">
  <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-indigo-100/50 blur-[120px]"></div>

  <div class="container-custom relative z-10">
    <div class="mb-16 grid gap-12 md:grid-cols-4">
      <div class="space-y-6 md:col-span-2">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 shadow-sm">
            <span class="text-2xl font-black text-indigo-600">D</span>
          </div>
          <div>
            <span class="text-2xl font-bold tracking-tighter text-slate-900">DIMS <span class="text-indigo-600">UCB</span></span>
            <p class="font-mono text-[10px] tracking-widest text-slate-500 uppercase">Advanced Research Lab</p>
          </div>
        </div>
        <p class="max-w-md text-sm leading-relaxed text-slate-600">
          Impulsando la frontera del conocimiento en Inteligencia Artificial, Mecatrónica y Desarrollo de Software desde la Universidad Católica Boliviana.
        </p>
      </div>

      <div>
        <h3 class="mb-6 flex items-center gap-2 font-bold text-slate-900">
          <span class="h-4 w-1 rounded-full bg-cyan-500"></span>
          Directorio
        </h3>
        <ul class="space-y-3 font-mono text-xs">
          {[
            { n: 'Noticias_Hub', h: '/noticias' },
            { n: 'Explorar_Carreras', h: '/#carreras' },
            { n: 'Calendario_Eventos', h: '/eventos' },
          ].map((link) => (
            <li>
              <a href={link.h} class="group flex items-center gap-2 text-slate-600 transition-colors hover:text-indigo-600">
                <span class="text-indigo-600/0 transition-all group-hover:text-indigo-600">{'>'}</span>
                {link.n}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-6 flex items-center gap-2 font-bold text-slate-900">
          <span class="h-4 w-1 rounded-full bg-indigo-500"></span>
          Contacto
        </h3>
        <div class="space-y-4 font-mono text-[11px]">
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
            <p class="mb-1 text-[9px] text-slate-500">CORREO</p>
            <p class="text-indigo-700 font-semibold">dims.scz@ucb.edu.bo</p>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
            <p class="mb-1 text-[9px] text-slate-500">UBICACIÓN</p>
            <p class="text-indigo-700 font-semibold">Campus UCB, Santa Cruz - BO</p>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 md:flex-row">
      <p class="font-mono text-[10px] tracking-widest text-slate-500 uppercase">
        &copy; {currentYear} DIMS Core v1.0.0 - Santa Cruz de la Sierra
      </p>
    </div>
  </div>
</footer>