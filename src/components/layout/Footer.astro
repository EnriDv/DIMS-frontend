---
const currentYear = new Date().getFullYear()
---

<footer class="relative overflow-hidden border-t border-white/5 bg-slate-950 pt-20 pb-10">
  <div
    class="absolute top-0 left-1/2 h-px w-full -translate-x-1/2 bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"
  >
  </div>
  <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-indigo-600/10 blur-[120px]">
  </div>

  <div class="container-custom relative z-10">
    <div class="mb-16 grid gap-12 md:grid-cols-4">
      <div class="space-y-6 md:col-span-2">
        <div class="flex items-center gap-3">
          <div
            class="flex h-12 w-12 items-center justify-center rounded-xl border border-white/10 bg-slate-900 shadow-[0_0_15px_rgba(99,102,241,0.2)]"
          >
            <span class="text-2xl font-black text-white">D</span>
          </div>
          <div>
            <span class="text-2xl font-bold tracking-tighter text-white"
              >DIMS <span class="text-cyan-400">UCB</span></span
            >
            <p class="font-mono text-[10px] tracking-widest text-slate-500 uppercase">
              Advanced Research Lab
            </p>
          </div>
        </div>
        <p class="max-w-md text-sm leading-relaxed text-slate-400">
          Impulsando la frontera del conocimiento en Inteligencia Artificial y Desarrollo de
          Software desde la Universidad Católica Boliviana.
        </p>
      </div>

      <div>
        <h3 class="mb-6 flex items-center gap-2 font-bold text-white">
          <span class="h-4 w-1 rounded-full bg-cyan-500"></span>
          Directorio
        </h3>
        <ul class="space-y-3 font-mono text-xs">
          {
            [
              { n: 'Noticias_Hub', h: '/noticias' },
              { n: 'Explorar_Carreras', h: '/#carreras' },
              { n: 'Calendario_Eventos', h: '/eventos' },
              { n: 'Investigaciones', h: '/investigaciones' },
              { n: 'Admisiones_2026', h: '/postulaciones' },
            ].map((link) => (
              <li>
                <a
                  href={link.h}
                  class="group flex items-center gap-2 text-slate-500 transition-colors hover:text-cyan-400"
                >
                  <span class="text-cyan-500/0 transition-all group-hover:text-cyan-500">
                    {'>'}
                  </span>
                  {link.n}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="mb-6 flex items-center gap-2 font-bold text-white">
          <span class="h-4 w-1 rounded-full bg-indigo-500"></span>
          Terminal_Info
        </h3>
        <div class="space-y-4 font-mono text-[11px]">
          <div class="rounded-lg border border-white/5 bg-white/5 p-3">
            <p class="mb-1 text-[9px] text-slate-500">ENVIAR_CORREO</p>
            <p class="text-indigo-300">dims.scz@ucb.edu.bo</p>
          </div>
          <div class="rounded-lg border border-white/5 bg-white/5 p-3">
            <p class="mb-1 text-[9px] text-slate-500">UBICACION_FISICA</p>
            <p class="text-indigo-300">Campus UCB, Santa Cruz - BO</p>
          </div>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-8 md:flex-row"
    >
      <p class="font-mono text-[10px] tracking-widest text-slate-600 uppercase">
        &copy; {currentYear} DIMS Core v1.0.0_Build - Santa Cruz de la Sierra
      </p>
      <div class="flex items-center gap-2">
        <span class="h-2 w-2 animate-pulse rounded-full bg-green-500"></span>
        <span class="font-mono text-[10px] tracking-widest text-slate-500 uppercase"
          >System_Online</span
        >
      </div>
    </div>
  </div>
</footer>
